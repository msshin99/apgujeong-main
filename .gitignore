node_modules
dist

# 이미지 파이프라인이 만들어 내는 것들 (scripts/optimize-images.mjs)
# .image-cache 는 구운 AVIF/WebP 사다리를 담아 두는 증분 캐시다. 수백 MB 까지
# 자랄 수 있고 원본에서 언제든 다시 만들 수 있으므로 커밋하지 않는다.
# src/generated 는 그 결과를 가리키는 매니페스트다. 빌드 산출물이라 역시 커밋하지
# 않는다 — 없으면 src/Img.jsx 가 평범한 <img> 로 떨어지도록 만들어 두었다.
.image-cache
src/generated

# 시각 회귀 검사 산출물 (scripts/visual-check.mjs)
# baseline/current/diff 에 라우트 × 화면폭 만큼의 전체 페이지 PNG 가 쌓인다. 63장에
# 수백 MB 다. 기준은 "지금 이 기계에서 방금 찍은 것" 이어야 의미가 있으므로 — 폰트 렌더링과
# 크로미움 판이 기계마다 다르다 — 커밋해서 돌려쓰는 물건이 아니다. 작업 시작 전에 각자
# npm run visual:baseline 로 새로 찍는다.
.visual

# 지도 키 등 환경변수는 커밋하지 않는다 (.env.example 만 공유)
.env
.env.local
.env.*.local

# Vercel CLI 작업 폴더
.vercel

# 에디터 · OS 부스러기
.DS_Store
Thumbs.db
*.log
