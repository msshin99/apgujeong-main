# 네이버 지도 (Maps JavaScript API v3)
# NAVER Cloud Platform 콘솔에서 Maps 애플리케이션을 만들고 발급받은 키를 넣는다.
# 콘솔의 "Web 서비스 URL"에 http://localhost:5173 과 실제 배포 도메인을 등록해야 동작한다.
VITE_NAVER_MAP_CLIENT_ID=

# 키 파라미터 이름. 발급 시점에 따라 다르다.
# 신규 발급 키는 ncpKeyId(기본값), 예전 키는 ncpClientId 를 쓴다.
# VITE_NAVER_MAP_KEY_PARAM=ncpClientId

# Supabase — 공지사항 / 문의하기 / 관리자 로그인
# Project Settings → API Keys 의 "anon public" 값을 넣는다.
# service_role 키는 절대 넣지 않는다. 설정 방법은 docs/supabase-setup.md 참고.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
